# ── Anthropic / Claude ──────────────────────────────────────────────────────
# Required for live NL→SQL generation and result summarisation
ANTHROPIC_API_KEY=sk-ant-...

# ── Microsoft Fabric ────────────────────────────────────────────────────────
# The SQL Analytics Endpoint hostname from your Fabric workspace
# Format: <workspace-id>.datawarehouse.fabric.microsoft.com
FABRIC_SQL_ENDPOINT=

# ── Microsoft Entra ID (Azure AD) SSO ───────────────────────────────────────
# Used for both staff authentication and Fabric SQL connection
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# ── NextAuth / Auth.js (optional) ───────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── Development ─────────────────────────────────────────────────────────────
# Leave FABRIC_SQL_ENDPOINT and ANTHROPIC_API_KEY empty to use mock data
NODE_ENV=development
